# URL base do seu Supabase self-hosted
SUPABASE_URL=https://srv521433.hstgr.cloud

# Chave de API (anon é suficiente — os dados são públicos e a leitura é só de SELECT).
# Fica apenas no servidor (rotas /api), nunca é exposta ao navegador.
SUPABASE_KEY=COLE_AQUI_A_ANON_KEY

# Chave service_role: usada SÓ na exportação CSV (sem statement_timeout).
# Também fica apenas no servidor. Se omitida, a exportação usa SUPABASE_KEY
# (sujeita ao timeout de 3s da role anon).
SUPABASE_SERVICE_KEY=COLE_AQUI_A_SERVICE_ROLE_KEY
